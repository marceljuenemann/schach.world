{% extends '@league/legacy-layout.html.twig' %}
{% import "@league/macros.html.twig" as macros %}
{% import "macros.html.twig" as nsv %}
{% set title = division.name ~ ': Runde ' ~ matchDay.round %} {# TODO: Add round? #}

{% block content %}

{# RESULTS #}
<div class="d-inline-block overflow-auto">
  {# TODO: only if there are any games #}
  {# TODO: further down #}
  {{ nsv.detailsToggle('DWZ anzeigen') }}
  <div class='nsv-table sed-ergebnisse'>
    {# TODO: anchor #}
    {% for pairing in matchDay.pairings %}
      <div class='nsv-table-header d-flex mt-4'>
        <div class='sed-mannschaft text-start'>{{ nsv.link(pairing.team1) }}</div>
        <div class='text-center'>&nbsp;{{ pairing.result|default(':') }}&nbsp;</div>
        <div class='sed-mannschaft text-end'>{{ nsv.link(pairing.team2) }}</div>
      </div>

      {% if pairing.wasBye %}
        <div class='nsv-table-cell text-center'>(kampflos)</div>
      {% elseif pairing.games|default(false) %}
        {% for game in pairing.games %}
          <div class='d-flex'>
            {# TODO: passnr #}
            {#}
            // Spieler 1
            if ( $staffel ['showPassNr'] ) {
              echo "<div class='nsv-table-cell sed-passnr d-none d-sm-block'>".$spielerpaarung["s1pass"]."</div>";
            }
            #}
            <div class='nsv-table-cell sed-spieler sed-spieler1'>
              {% if game.player1 %}
                <div class='sed-name'>{{ nsv.link(game.player1) }}</div>
                <div class='sed-dwz nsv-details align-self-end'>{% if game.player1.dwz %}({{ game.player1.dwz }}){% endif %}</div>
              {% endif %}
            </div>
            <div class='nsv-table-cell sed-ergebnis'>
              {{ game.result1 }} &nbsp;:&nbsp; {{ game.result2 }}
            </div>
            <div class='nsv-table-cell sed-spieler sed-spieler2'>
              {% if game.player2 %}
                <div class='sed-dwz nsv-details align-self-end'>{% if game.player2.dwz %}({{ game.player2.dwz }}){% endif %}</div>
                <div class='sed-name'>{{ nsv.link(game.player2) }}</div>
              {% endif %}
            </div>

            {#if ( $staffel ['showPassNr'] ) {
              echo "<div class='nsv-table-cell sed-passnr d-none d-sm-block'>".$spielerpaarung["s2pass"]."</div>";
            }
            #}

          </div>
        {% endfor %}
      {% else %}
        {% if pairing.wasMoved %}
          {% if pairing.moveDate %}
            <div class='nsv-table-cell text-center'>Verlegt auf den {{ pairing.moveDate|date('d.m.Y') }}</div>
          {% else %}
            <div class='nsv-table-cell text-center'>Spiel verlegt</div>
          {% endif %}
        {% endif %}
        {% if pairing.host %}
          <div class='nsv-table-cell text-center'>Ausrichter: {{ nsv.link(pairing.host) }}</div>
        {% endif %}
      {% endif %}

      {% if pairing.comment %}
        <p class="fst-italic mt-2">{{ pairing.comment }}</p>
      {% endif %}
    {% endfor %}

  </div>

</div>

{% endblock %}


