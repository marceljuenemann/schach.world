{% extends '@league/legacy-layout.html.twig' %}
{% import "@league/macros.html.twig" as macros %}
{% set title = division.name %}

{% block content %}
<div class="nsv-table">
  {% for matchDay in matchDays %}
    <h4 class="mt-4"><a href="{{matchDay.uri}}">{{matchDay.round}}. Spieltag &ndash; {{matchDay.date|date('d.m.Y')}}</a></h4>
    {{ macros.pairings(matchDay.pairings) }}
  {% endfor %}
</div>
{% endblock %}
