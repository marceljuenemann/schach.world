{% extends '@league/legacy-layout.html.twig' %}
{% import "@league/macros.html.twig" as macros %}
{% import "macros.html.twig" as nsv %}

{% block headline %}

  <h2>
    <span class="d-none d-lg-inline-block">{{ division.name }}</span>
    <span class="dropdown d-lg-none">
      <span class="dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">{{ division.name }}</span>
      <ul class="dropdown-menu">
        {% for d in league.divisions %}
          <li><a class="dropdown-item" href="{{ d.uri }}">{{ d.name }}</a></li>
        {% endfor %}
      </ul>
    </span>
  </h2>

{% endblock %}
