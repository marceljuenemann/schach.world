{% extends 'email/layout.html.twig' %}
{% import "email/bootstrap.html.twig" as bs %}

{% block headline %}
  {{ config.group(player.group).name }}
{% endblock %}

{% block content %}

  {% if (player.waitlist) %}
    {{ bs.alert_danger }}
      <b>Warteliste:</b> Die Anmeldegrenze für dieses Turnier ist bereits erreicht, daher kann die
      Teilnahme nicht garantiert werden. Sie sind nun aber auf der Warteliste und werden benachrichtigt,
      sollte ein Platz frei werden.
    {{ bs.endalert }}
  {% elseif (waitlistConfirmation) %}
    {{ bs.alert_success }}
      <b>Anmeldung erfolgreich:</b> Ihre Anmeldung wurde von der Warteliste in das Turnier aufgenommen.
      Falls Sie nicht länger am Turnier teilnehmen können, wenden Sie sich bitte an die Turnierleitung.
      Sie können dazu auf diese E-Mail antworten.
    {{ bs.endalert }}
  {% endif %}

  {{ bs.dd('Name') }} {{ player.playerData.name }} {{ bs.end_dd }}
  {{ bs.dd('Verein') }} {{ player.playerData.club }} {{ bs.end_dd }}
  {{ bs.dd('Kontakt') }} {{ player.contactDetails.name }} {{ bs.end_dd }}
  {{ bs.dd('Email') }} {{ player.contactDetails.email }} {{ bs.end_dd }}

  {% if config.additionalFields %}
    {% for fieldConfig in config.additionalFields %}
      {{ bs.dd(fieldConfig.label) }}
        {% if fieldConfig.type == 'select' %}
          {% for option in fieldConfig.options %}
            {% if option.value == player.additionalFields[fieldConfig.id] %}
              {{ option.label }}
            {% endif %}
          {% endfor %}
        {% else %}
          {{ player.additionalFields[fieldConfig.id] | default('') | nl2br }}
        {% endif %}
      {{ bs.end_dd }}
    {% endfor %}
  {% endif %}

  {{ bs.hr }}

  {% if (player.playerData.zps) %}
    {{ bs.alert_success }} 
      Es wurde ein Eintrag in der DWZ-Datenbank gefunden 
    {{ bs.endalert }}
    {{ bs.dd('DWZ') }} {{ player.playerData.dwz }} {{ bs.end_dd }}
    {{ bs.dd('ELO') }} {{ player.playerData.elo }} {{ bs.end_dd }}
    {{ bs.dd('Titel') }} {{ player.playerData.fideTitle }} {{ bs.end_dd }}
    {{ bs.dd('FIDE-ID') }} {{ player.playerData.fideId }} {{ bs.end_dd }}
    {{ bs.dd('ZPS') }} {{ player.playerData.zps }}-{{ player.playerData.memberId }} {{ bs.end_dd }}
  {% else %}
    {{ bs.alert_warning }}
      Es wurde kein Eintrag in der DWZ-Datenbank gefunden. Die folgenden Daten wurden manuell eingetragen.
    {{ bs.endalert }}
    {{ bs.dd('Geburt') }} {{ player.playerData.yearOfBirth }} {{ bs.end_dd }}
    {{ bs.dd('Geschlecht') }} {{ player.playerData.gender }} {{ bs.end_dd }}
  {% endif %}

  {{ bs.hr }}

  {{ bs.link(overviewUri) }} Aktuelle Meldeliste {{ bs.endlink }}

{% endblock %}
